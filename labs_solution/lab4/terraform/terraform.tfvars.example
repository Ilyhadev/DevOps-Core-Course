# Copy this file to terraform/terraform.tfvars and fill with real values.

cloud_id = "your-cloud-id"
folder_id = "your-folder-id"
zone = "ru-central1-a"
instance_name = "your-name"
cores = 2
core_fraction = 20
memory = 2
boot_disk_size = 10
ssh_public_key_path = "~/.ssh/lab04_id_rsa.pub"
ssh_user = "ubuntu"
# Set to your public IP (e.g. 203.0.113.5/32) to restrict SSH
my_ip_cidr = "<your-ip>/32"
